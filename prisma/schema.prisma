generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Developer {
  id               String   @id @default(cuid())
  name             String
  role             String
  status           String   @default("Active") // Active, Inactive
  weeklyHours      Int      @default(40)
  preferredWork    String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  skills           DeveloperSkill[]
  projects         ProjectDeveloper[]
  dailyPlans       DailyPlan[]
  dailyUpdates     DailyUpdate[]
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // Frontend, Backend, Mobile, CMS, Cloud, Database, QA, Design, Other
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  developers  DeveloperSkill[]
}

model DeveloperSkill {
  id          String   @id @default(cuid())
  developerId String
  skillId     String
  level       String   // Primary, Secondary, Learning

  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([developerId, skillId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String?
  type        String   // Website, Mobile App, Admin Panel, Backend, Shopify, WordPress, CMS, Maintenance, Other
  status      String   @default("Active") // Active, Completed, On Hold, Cancelled
  startDate   DateTime?
  endDate     DateTime?
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  developers  ProjectDeveloper[]
  dailyPlans  DailyPlan[]
  dailyUpdates DailyUpdate[]
}

model ProjectDeveloper {
  id          String   @id @default(cuid())
  projectId   String
  developerId String
  role        String

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@unique([projectId, developerId])
}

model DailyPlan {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  developerId    String
  projectId      String
  taskTitle      String
  workType       String   // Development, Bug Fix, QA, Deployment, Research, Documentation, Client Support, Code Review, Planning
  technologies   String   // JSON string or comma separated
  expectedEffort Float
  priority       String   // Low, Medium, High
  dependency     String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  developer      Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  dailyUpdate    DailyUpdate?
}

model DailyUpdate {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  developerId    String
  projectId      String
  dailyPlanId    String?  @unique
  taskTitle      String
  workType       String
  technologies   String
  status         String   // Done, In Progress, Blocked, Carried Forward, Cancelled
  actualEffort   Float
  workCompleted  String?
  workPending    String?
  blocker        String?
  summary        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  developer      Developer  @relation(fields: [developerId], references: [id], onDelete: Cascade)
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyPlan      DailyPlan? @relation(fields: [dailyPlanId], references: [id], onDelete: SetNull)
}
